   "host_permissions": [ "wss://*/*", "https://*.branch.io/*", "https://binomo.com/*", "*://*.binomo.com/*", "https://api.binomo.com/*", "https://promo.binomobot.com/*", "https://bst.ppnet.systems/*", "https://binomobot.com/*", "https://api.binomobot.com/*", "https://marketing.work.ppnet.io/*", "https://binobot.co/*", "https://assets.binobot.co/*", "https://api.binobot.co/*" ],
